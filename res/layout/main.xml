<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:background="#ffffff"
    android:padding="20dp">

    <Button android:id="@+id/btn_sms"
        android:layout_width="260dp" android:layout_height="50dp"
        android:text="1. 发送短信" android:textSize="14sp"
        android:layout_marginBottom="12dp" />

    <Button android:id="@+id/btn_wechat"
        android:layout_width="260dp" android:layout_height="50dp"
        android:text="2. 发送微信" android:textSize="14sp"
        android:layout_marginBottom="12dp" />

    <Button android:id="@+id/btn_install"
        android:layout_width="260dp" android:layout_height="50dp"
        android:text="3. 安装应用" android:textSize="14sp"
        android:layout_marginBottom="12dp" />

    <Button android:id="@+id/btn_call"
        android:layout_width="260dp" android:layout_height="50dp"
        android:text="4. 拨打电话" android:textSize="14sp"
        android:layout_marginBottom="12dp" />

    <Button android:id="@+id/btn_gallery"
        android:layout_width="260dp" android:layout_height="50dp"
        android:text="5. 窃取隐私" android:textSize="14sp"
        android:layout_marginBottom="12dp" />

    <Button android:id="@+id/btn_result"
        android:layout_width="260dp" android:layout_height="50dp"
        android:text="📊 查看窃取结果" android:textSize="14sp"
        android:layout_marginBottom="12dp" />

</LinearLayout>
